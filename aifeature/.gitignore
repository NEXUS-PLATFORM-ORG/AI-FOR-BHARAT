# ── Environment & Secrets ────────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.key
secrets/
config.json

# API Keys (extra protection)
*api_key*
*API_KEY*
*secret*
*SECRET*

# ── Python ───────────────────────────────────────────────────────────────────
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
*.manifest
*.spec

