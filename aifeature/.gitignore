# ── Backup & Archive Files ────────────────────────────────────────────────────
*.bak
*.backup
*.old
*.orig
*.save
*.zip
*.tar
*.tar.gz
*.tgz
*.rar
*.7z

# ── Test Files ────────────────────────────────────────────────────────────────
# Test outputs
test_output/
test_results/
*.test

# Sample/demo files (if they contain real data)
samples/
demo/
examples/

# ── Performance & Profiling ───────────────────────────────────────────────────
*.prof
*.profile
.benchmarks/

# ── Documentation Build ───────────────────────────────────────────────────────
docs/build/
docs/_build/

# ── Custom Project Exclusions ─────────────────────────────────────────────────
# Add any project-specific files to ignore here

# Ollama model cache (if stored locally)
.ollama/

# Custom configuration overrides
config.local.py
settings.local.py

# Development scripts
dev_*
test_*
debug_*
scratch_*

# ══════════════════════════════════════════════════════════════════════════════
# IMPORTANT SECURITY NOTES:
# 
# 1. NEVER commit .env files - they contain API keys
# 2. NEVER commit actual PDF documents - they may contain sensitive legal data
# 3. NEVER commit extracted JSON - it contains processed sensitive information
# 4. Review any new files before committing to ensure no secrets are included
# ══════════════════════════════════════════════════════════════════════════════