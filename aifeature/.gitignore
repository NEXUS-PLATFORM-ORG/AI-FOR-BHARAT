# ── Document Processing Data ──────────────────────────────────────────────────
# Input PDFs (sensitive legal documents)
data/input_pdfs/*.pdf
data/input_pdfs/**/*.pdf

# Output JSON (extracted sensitive data)
data/output_json/*.json
data/output_json/**/*.json

# Debug files and logs
data/debug/
*.log
logs/

# Temporary processing files
temp/
tmp/
*.tmp
*.temp

# OCR temporary files
*.tiff
*.tif
*.png
*.jpg
*.jpeg
*.bmp

# ── IDE & Editor Files ────────────────────────────────────────────────────────
# VSCode
.vscode/
*.code-workspace

# PyCharm
.idea/
*.iml
*.ipr
*.iws

# Sublime Text
*.sublime-project
*.sublime-workspace

